{
  "version": 2,
  "functions": { "api/*.cjs": { "runtime": "nodejs20.x" } },
  "routes": [
    { "src": "/api/ping", "dest": "/api/ping.cjs" },
    { "src": "/api/mux-env-check", "dest": "/api/mux-env-check.cjs" },
    { "src": "/api/mux-direct-upload", "dest": "/api/mux-direct-upload.cjs" },
    { "src": "/api/ok", "dest": "/api/ok.cjs" },
    { "src": "/(.*)", "dest": "/" }
  ]
}
