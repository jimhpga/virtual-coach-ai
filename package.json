{
    "name":  "virtualcoachai",
    "version":  "1.0.0",
    "description":  "Virtual Coach AI App",
    "main":  "index.js",
    "license":  "MIT",
    "private":  true,
    "scripts":  {
                    "preflight":  "node scripts/preflight.js",
                    "clean":  "rimraf dist build .pack \u0026\u0026 shx mkdir -p .pack",
                    "build":  "vite build",
                    "_build":  "vite build",
                    "pack":  "node scripts/pack.js",
                    "zip":  "node scripts/zip.js",
                    "release":  "npm-run-all -s preflight build pack zip",
                    "dev":  "vite --host 127.0.0.1 --port 5173 --strictPort",
                    "start":  "vite preview"
                },
    "dependencies":  {
                         "@aws-sdk/client-s3":  "^3.883.0",
