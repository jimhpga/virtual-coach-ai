                         "react-dom":  "^18.3.1"
                     },
    "devDependencies":  {
                            "chalk":  "^5.3.0",
                            "cross-zip":  "^4.0.0",
                            "esbuild":  "^0.25.9",
                            "npm-run-all":  "^4.1.5",
                            "rimraf":  "^5.0.10",
                            "shx":  "^0.3.4",
                            "simple-git":  "^3.27.0",
                            "vite":  "^7.1.5"
                        }
}